# Deployer private key (EOA — pays gas only, discard after deploy)
PRIVATE_KEY=

# Gnosis Safe multisig address (receives 1B SWARM + contract ownership)
# Production BSC Safe: 0x26eFA122d6f3bFe97A946768eeCb49379A953121
GNOSIS_SAFE=

# NodeReal API key (for contract verification on opBNBscan)
NODEREAL_API_KEY=

# RPC URLs (optional — defaults are set in hardhat.config.js)
OPBNB_RPC_URL=https://opbnb-mainnet-rpc.bnbchain.org
OPBNB_TESTNET_RPC_URL=https://opbnb-testnet-rpc.bnbchain.org:8545
