# Deployer private key (EOA — pays gas only, discard after deploy)
PRIVATE_KEY=

# Gnosis Safe multisig address (receives tokens + contract ownership)
# Production BSC Safe: 0x26eFA122d6f3bFe97A946768eeCb49379A953121
GNOSIS_SAFE=

# NodeReal API key — for opBNBscan contract verification
# Get one free at: https://nodereal.io
NODEREAL_API_KEY=

# BscScan API key — for BSC contract verification at TGE
# Get one free at: https://bscscan.com/apis
BSCSCAN_API_KEY=

# RPC URLs (optional — hardhat.config.js defaults work without these)
# Use NodeReal for a more reliable opBNB RPC:
# OPBNB_RPC_URL=https://opbnb-mainnet.nodereal.io/v1/YOUR_NODEREAL_KEY
OPBNB_RPC_URL=
OPBNB_TESTNET_RPC_URL=
BSC_RPC_URL=
